# Dream.OS websites VPS runtime — copy to /opt/dreamos/secrets/websites.env
# Placeholders only. Never commit real secrets to the websites repo.

DREAMOS_ROOT=/opt/dreamos
WEBSITES_REPO=/opt/dreamos/repos/websites
DREAMVAULT_REPO=/opt/dreamos/repos/DreamVault
DREAM_DATA_VAULT_REPO=/opt/dreamos/repos/dream-data-vault
DREAMOS_BRAIN_REPO=/opt/dreamos/repos/dreamos-brain
DASHBOARD_RUNTIME_DIR=/opt/dreamos/runtime/dashboard
SITE_PREVIEW_PORT=8080
PUBLIC_SITE_ROOT=/var/www/dreamos-sites

# Optional overrides (defaults derived from PUBLIC_SITE_ROOT when unset)
# DASHBOARD_SITE_DATA_DIR=/var/www/dreamos-sites/weareswarm.online/data/planner
# DASHBOARD_PUBLIC_DATA_DIR=/var/www/dreamos-sites/data/dashboard
# SITE_PREVIEW_ROOT=/var/www/dreamos-sites/weareswarm.online
# VPS_REPORTS_DIR=/opt/dreamos/repos/websites/reports/vps
