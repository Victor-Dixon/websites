# Dream.OS static sites — example nginx server block for Ubuntu 24.04
# Copy to /etc/nginx/sites-available/ and symlink manually; NOT auto-deployed.
#
#   sudo cp deploy/vps/websites/nginx/dreamos-sites.conf.example \
#       /etc/nginx/sites-available/dreamos-sites.conf
#   sudo ln -sf /etc/nginx/sites-available/dreamos-sites.conf \
#       /etc/nginx/sites-enabled/dreamos-sites.conf
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name example.dreamos.local;

    root /var/www/dreamos-sites;
    index index.html index.htm;

    # Static site files
    location / {
        try_files $uri $uri/ =404;
    }

    # Optional public dashboard JSON (sanitized exports only)
    location /data/ {
        alias /var/www/dreamos-sites/data/;
        default_type application/json;
        add_header Cache-Control "public, max-age=60";
        add_header X-Content-Type-Options nosniff always;
    }

    # Site-specific planner JSON (weareswarm.online mirror)
    location /weareswarm.online/data/planner/ {
        alias /var/www/dreamos-sites/weareswarm.online/data/planner/;
        default_type application/json;
        add_header Cache-Control "public, max-age=60";
        add_header X-Content-Type-Options nosniff always;
    }

    # Local-only health endpoint (bind nginx to 127.0.0.1 or restrict by IP)
    # Uncomment and point to a static health file generated by healthcheck.sh:
    #
    # location = /healthz {
    #     allow 127.0.0.1;
    #     deny all;
    #     alias /var/www/dreamos-sites/.well-known/healthz.json;
    #     default_type application/json;
    # }

    access_log /var/log/nginx/dreamos-sites.access.log;
    error_log  /var/log/nginx/dreamos-sites.error.log;
}
