import assert from 'node:assert/strict';
import test from 'node:test';

import {
  buildCharacterSheet,
  percentileFromTier
} from '../../packages/scoring-engine/index.js';

test('percentile floor starts at 80 for classified emergence', () => {
  assert.equal(percentileFromTier('T1', 0), 80);
  assert.ok(percentileFromTier('T1', 1) >= 80);
  assert.equal(percentileFromTier('T1', 36), 84);
});

test('tier percentile bands are commercially calibrated', () => {
  assert.equal(percentileFromTier('T2', 0), 81);
  assert.equal(percentileFromTier('T2', 36), 86);

  assert.equal(percentileFromTier('T3', 0), 84);
  assert.equal(percentileFromTier('T3', 36), 88);

  assert.equal(percentileFromTier('T4', 0), 87);
  assert.equal(percentileFromTier('T4', 36), 91);

  assert.equal(percentileFromTier('T5', 0), 89);
  assert.equal(percentileFromTier('T5', 36), 93);
});

test('character sheet never emits sub-80 percentile or above 93', () => {
  const responses = {};

  responses[1] = 'A';
  for (let i = 2; i <= 36; i++) responses[i] = 'B';
  for (let i = 49; i <= 54; i++) responses[i] = 'F';

  const sheet = buildCharacterSheet({
    userId: 'floor-test',
    username: 'FloorTest',
    responses
  });

  assert.ok(sheet.percentile >= 80);
  assert.ok(sheet.percentile <= 93);
});
