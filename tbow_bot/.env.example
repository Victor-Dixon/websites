# TBOW Bot Environment Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════
# WEBHOOK SECURITY
# ═══════════════════════════════════════════════════════════════════════════
# Long random string for webhook authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TBOW_WEBHOOK_SECRET=

# Server binding
TBOW_WEBHOOK_HOST=0.0.0.0
TBOW_WEBHOOK_PORT=8000

# ═══════════════════════════════════════════════════════════════════════════
# WORDPRESS (tradingrobotplug.com)
# ═══════════════════════════════════════════════════════════════════════════
# Your WordPress site URL (no trailing slash)
WP_BASE=https://tradingrobotplug.com

# WordPress username with editor/author permissions
WP_USER=

# Application Password (generate in WP Admin → Users → Your Profile)
# Include spaces as shown: xxxx xxxx xxxx xxxx xxxx xxxx
WP_APP_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# PUBLISHING OPTIONS
# ═══════════════════════════════════════════════════════════════════════════
# Default post status: "draft" or "publish"
TBOW_POST_STATUS=draft

# ═══════════════════════════════════════════════════════════════════════════
# TRADING OPTIONS (v2)
# ═══════════════════════════════════════════════════════════════════════════
# Strike selection for options: "ATM" or "1_ITM"
TBOW_STRIKE_SELECTION=ATM
