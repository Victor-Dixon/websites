{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1180px",
      "wideSize": "1180px"
    },
    "color": {
      "palette": [
        { "slug": "dream-bg", "color": "#030712", "name": "Dream BG" },
        { "slug": "dream-text", "color": "#f8fbff", "name": "Dream Text" },
        { "slug": "dream-muted", "color": "#aab7c8", "name": "Dream Muted" },
        { "slug": "dream-cyan", "color": "#7df9ff", "name": "Spark Cyan" },
        { "slug": "dream-violet", "color": "#b76cff", "name": "Spark Violet" },
        { "slug": "dream-pink", "color": "#ff4fd8", "name": "Spark Pink" },
        { "slug": "dream-green", "color": "#38f8b1", "name": "Spark Green" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#030712",
      "text": "#f8fbff"
    },
    "typography": {
      "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Arial, sans-serif"
    }
  }
}
