- */
-function getFastApiUrl() {
-    // Check if WordPress config provides override
-    if (typeof tradingRobotPlugConfig !== 'undefined' && tradingRobotPlugConfig.fastApiUrl) {
-        return tradingRobotPlugConfig.fastApiUrl;
